<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WarframeWork.Pages.UtilityPage"
             Title="UtilityPage">
    <ScrollView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Text="Search"
                   Grid.Row="0"
                   Grid.Column="0"/>
            <Entry x:Name="searchInput"
                   VerticalOptions="CenterAndExpand"
                   Grid.Column="0"
                   Grid.Row="1"
                   Grid.ColumnSpan="3"/>
            <HorizontalStackLayout x:Name="searchlayout"
                                   RadioButtonGroup.GroupName="searchGroupName"
                                   RadioButtonGroup.SelectedValue="{Binding searchGroupItem}"
                Grid.Row="2">
                <RadioButton Content="All"
                             Value="items"
                             IsChecked="True"/>
                <RadioButton Content="Warframe"
                             Value="warframes"/>
                <RadioButton Content="Weapon"
                             Value="weapons"/>
                <RadioButton Content="Mods"
                             Value="mods"/>
            </HorizontalStackLayout>
            <Button Text="Retrieve Data"
                    VerticalOptions="CenterAndExpand"
                    Clicked="DataRetrievalClick"
                    Grid.Row="3"
                    Grid.Column="0"/>
            <CollectionView 
                x:Name="retrievedCollection"
                x:FieldModifier="public"
                SelectionMode="Single"
                SelectionChanged="itemSelected"
                Grid.Row="4"
                Grid.Column="0"
                Grid.ColumnSpan="3">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                               Text="{Binding name}"/>
                            <Label Grid.Column="1"
                               Text="{Binding uniqueName}"/>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ScrollView>
</ContentPage>