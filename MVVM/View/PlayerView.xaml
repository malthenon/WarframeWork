<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WarframeWork.MVVM.View.PlayerView"
             Title="PlayerView">
    <HorizontalStackLayout>
        <VerticalStackLayout>
            <Label Text="Enter player name"
                   Grid.Row="0"
                   Grid.Column="0"/>            
            <Entry x:Name="searchInput"
                   VerticalOptions="CenterAndExpand"
                   Grid.Column="0"
                   Grid.Row="1"
                   Grid.ColumnSpan="3"/>
            <Button Text="Retrieve Data"
                    VerticalOptions="CenterAndExpand"
                    Clicked="DataRetrievalClick"
                    Grid.Row="2"
                    Grid.Column="0"/>
        </VerticalStackLayout>
    </HorizontalStackLayout>
</ContentPage>